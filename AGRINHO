<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AGRO VISION 2050 | O Futuro Nasce no Campo</title>

<style>
:root{
    --lime:#C6FF00;
    --green:#39FF14;
    --black:#050505;
    --white:#ffffff;
    --dark:#0d0d0d;
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family: "Segoe UI", sans-serif;
    scroll-behavior:smooth;
}

body{
    background:var(--black);
    color:var(--white);
    overflow-x:hidden;
}

/* Fundo futurista */
.background{
    position:fixed;
    inset:0;
    z-index:-2;
    background:
        radial-gradient(circle at 20% 20%, rgba(198,255,0,.15), transparent 20%),
        radial-gradient(circle at 80% 30%, rgba(57,255,20,.1), transparent 20%),
        radial-gradient(circle at 50% 80%, rgba(198,255,0,.12), transparent 25%),
        #050505;
    animation: moveBg 12s infinite alternate;
}

@keyframes moveBg{
    from{transform:scale(1);}
    to{transform:scale(1.15);}
}

/* Linhas futuristas */
.grid{
    position:fixed;
    inset:0;
    background:
    linear-gradient(rgba(198,255,0,.05) 1px, transparent 1px),
    linear-gradient(90deg, rgba(198,255,0,.05) 1px, transparent 1px);
    background-size:50px 50px;
    z-index:-1;
}

/* Menu */
nav{
    position:fixed;
    top:0;
    width:100%;
    padding:20px;
    display:flex;
    justify-content:center;
    backdrop-filter:blur(10px);
    background:rgba(0,0,0,.4);
    border-bottom:1px solid rgba(198,255,0,.2);
    z-index:1000;
}

nav ul{
    display:flex;
    gap:35px;
    list-style:none;
}

nav a{
    text-decoration:none;
    color:white;
    font-weight:600;
    transition:.3s;
}

nav a:hover{
    color:var(--lime);
    text-shadow:0 0 10px var(--lime);
}

/* Hero */
.hero{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    flex-direction:column;
    text-align:center;
    padding:20px;
}

.logo{
    font-size:5rem;
    font-weight:900;
    color:var(--lime);
    text-shadow:
        0 0 10px var(--lime),
        0 0 30px var(--lime),
        0 0 60px var(--green);
    animation:pulse 3s infinite;
}

@keyframes pulse{
    50%{
        transform:scale(1.05);
    }
}

.tag{
    margin-top:20px;
    color:var(--white);
    font-size:1.4rem;
    max-width:900px;
}

.highlight{
    color:var(--lime);
}

.cta{
    margin-top:35px;
    padding:16px 40px;
    border:none;
    border-radius:50px;
    background:var(--lime);
    color:black;
    font-weight:bold;
    cursor:pointer;
    transition:.4s;
    box-shadow:0 0 25px var(--lime);
}

.cta:hover{
    transform:translateY(-5px) scale(1.05);
    box-shadow:0 0 50px var(--lime);
}

/* Sections */
section{
    padding:100px 10%;
}

.title{
    text-align:center;
    font-size:3rem;
    color:var(--lime);
    margin-bottom:50px;
    text-shadow:0 0 15px var(--lime);
}

.cards{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:30px;
}

.card{
    background:rgba(255,255,255,.03);
    border:1px solid rgba(198,255,0,.2);
    border-radius:20px;
    padding:30px;
    transition:.4s;
}

.card:hover{
    transform:translateY(-10px);
    box-shadow:0 0 25px rgba(198,255,0,.4);
}

.card h3{
    color:var(--lime);
    margin-bottom:15px;
}

/* Impacto */
.stats{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:40px;
    text-align:center;
}

.stat{
    padding:30px;
}

.number{
    font-size:4rem;
    font-weight:900;
    color:var(--lime);
    text-shadow:0 0 20px var(--lime);
}

/* CTA final */
.future{
    text-align:center;
    background:linear-gradient(135deg,#0d0d0d,#111);
    border-top:1px solid rgba(198,255,0,.2);
}

.future p{
    max-width:900px;
    margin:auto;
    font-size:1.2rem;
    line-height:1.8;
}

/* Footer */
footer{
    padding:30px;
    text-align:center;
    border-top:1px solid rgba(198,255,0,.2);
    background:black;
}

footer span{
    color:var(--lime);
}

#message{
    margin-top:25px;
    color:var(--lime);
    font-weight:bold;
    font-size:1.1rem;
}

/* Responsivo */
@media(max-width:768px){

    .logo{
        font-size:3rem;
    }

    .tag{
        font-size:1rem;
    }

    .title{
        font-size:2rem;
    }

    nav ul{
        gap:15px;
        font-size:.9rem;
    }
}
</style>
</head>

<body>

<div class="background"></div>
<div class="grid"></div>

<nav>
    <ul>
        <li><a href="#sobre">Sobre</a></li>
        <li><a href="#tecnologia">Tecnologia</a></li>
        <li><a href="#impacto">Impacto</a></li>
        <li><a href="#futuro">Futuro</a></li>
    </ul>
</nav>

<header class="hero">

    <h1 class="logo">AGRO VISION 2050</h1>

    <p class="tag">
        <span class="highlight">O FUTURO NASCE NO CAMPO.</span><br>
        Tecnologia, sustentabilidade e inovação conectando pessoas,
        natureza e produtividade para alimentar o mundo de forma inteligente.
    </p>

    <button class="cta" onclick="mostrarMensagem()">
        Descobrir o Futuro
    </button>

    <div id="message"></div>

</header>

<section id="sobre">

    <h2 class="title">🌱 Agro Forte e Sustentável</h2>

    <div class="cards">

        <div class="card">
            <h3>Produção Inteligente</h3>
            <p>
                Utilizamos dados, inovação e eficiência para produzir mais
                utilizando menos recursos naturais.
            </p>
        </div>

        <div class="card">
            <h3>Sustentabilidade Real</h3>
            <p>
                Preservação ambiental e crescimento econômico trabalhando juntos
                para garantir o futuro das próximas gerações.
            </p>
        </div>

        <div class="card">
            <h3>Alto Desempenho</h3>
            <p>
                Soluções modernas aumentam a produtividade sem comprometer a saúde
                do solo, da água e dos ecossistemas.
            </p>
        </div>

    </div>

</section>

<section id="tecnologia">

    <h2 class="title">🚀 Campo Digital</h2>

    <div class="cards">

        <div class="card">
            <h3>🤖 Inteligência Artificial</h3>
            <p>
                Monitoramento de safras, previsões climáticas e análises
                inteligentes em tempo real.
            </p>
        </div>

        <div class="card">
            <h3>📡 Sensores e Drones</h3>
            <p>
                Precisão máxima para otimizar recursos e reduzir desperdícios.
            </p>
        </div>

        <div class="card">
            <h3>⚡ Energia Renovável</h3>
            <p>
                Fontes limpas impulsionando um agro mais eficiente e sustentável.
            </p>
        </div>

    </div>

</section>

<section id="impacto">

    <h2 class="title">📊 Impacto Positivo</h2>

    <div class="stats">

        <div class="stat">
            <div class="number" id="n1">0</div>
            <h3>Eficiência</h3>
        </div>

        <div class="stat">
            <div class="number" id="n2">0</div>
            <h3>Inovação</h3>
        </div>

        <div class="stat">
            <div class="number" id="n3">0</div>
            <h3>Sustentabilidade</h3>
        </div>

        <div class="stat">
            <div class="number" id="n4">0</div>
            <h3>Tecnologia</h3>
        </div>

    </div>

</section>

<section id="futuro" class="future">

    <h2 class="title">🌎 O Amanhã Está Sendo Cultivado Hoje</h2>

    <p>
        O agronegócio do futuro será conectado, inteligente e sustentável.
        Cada hectare cultivado com responsabilidade representa mais alimento,
        mais inovação e mais oportunidades para o planeta.
        A tecnologia transforma o campo em uma potência capaz de alimentar o mundo
        preservando os recursos naturais.
    </p>

    <br><br>

    <button class="cta" onclick="window.scrollTo({top:0,behavior:'smooth'})">
        Voltar ao Topo
    </button>

</section>

<footer>
    © 2026 <span>AGRO VISION 2050</span> • Cultivando o futuro com tecnologia e sustentabilidade.
</footer>

<script>
function mostrarMensagem(){
    document.getElementById("message").innerHTML =
    "🚜 O agro do futuro já começou: mais tecnologia, mais produtividade e mais sustentabilidade.";
}

function animate(id,target){
    let n=0;
    const el=document.getElementById(id);

    const timer=setInterval(()=>{
        n++;
        el.innerHTML=n+"%";

        if(n>=target){
            clearInterval(timer);
        }
    },20);
}

const observer=new IntersectionObserver(entries=>{
    if(entries[0].isIntersecting){

        animate("n1",95);
        animate("n2",98);
        animate("n3",100);
        animate("n4",97);

        observer.disconnect();
    }
});

observer.observe(document.querySelector("#impacto"));
</script>

</body>
</html>
